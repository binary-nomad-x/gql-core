{
  "name": "gql-monorepo",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "start:api": "nest start api --watch -- --port 3001",
    "start:web": "ng serve frontend --port 4201",
    "dev": "concurrently -n \"API,WEB\" -c \"cyan,magenta\" \"npm run start:api\" \"npm run start:web\"",
    "build": "npm run build:api && npm run build:web",
    "build:api": "nest build api",
    "build:web": "ng build frontend",
    "db:gen": "prisma generate",
    "db:push": "prisma db push",
    "db:push:force": "prisma db push --accept-data-loss",
    "db:migrate": "prisma migrate dev",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset --force",
    "db:status": "prisma migrate status",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "postinstall": "prisma generate",
    "db:sync": "prisma db push --accept-data-loss && prisma generate",
    "db:sync:seed": "prisma db push --accept-data-loss && prisma generate && prisma db seed"
  },
  "dependencies": {
    "@angular/animations": "^19.1.0",
    "@angular/common": "^19.1.0",
    "@angular/compiler": "^19.1.0",
    "@angular/core": "^19.1.0",
    "@angular/forms": "^19.1.0",
    "@angular/platform-browser": "^19.1.0",
    "@angular/platform-browser-dynamic": "^19.1.0",
    "@angular/router": "^19.1.0",
    "@apollo/client": "^4.1.6",
    "@apollo/server": "^5.0.0",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.0.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/graphql": "^13.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.0",
    "ag-grid-angular": "^35.1.0",
    "ag-grid-community": "^35.1.0",
    "apollo-angular": "^13.0.0",
    "bcrypt": "^6.0.0",
    "graphql": "^16.10.0",
    "pg": "^8.19.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.1.0",
    "@angular/cli": "^19.1.0",
    "@angular/compiler-cli": "^19.1.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.10.10",
    "@types/pg": "^8.18.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.8",
    "prisma": "^7.4.0",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.7.3"
  }
}
