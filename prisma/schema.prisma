generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  ADMIN
  MEMBER
}

model Gender {
  id String @id @default(uuid())
  name String
  users User[]
}

model User {
  id String @id @default(uuid())
  email String @unique
  password String
  name String?
  role Role @default(MEMBER)

  genderId String?
  gender Gender? @relation(fields: [genderId], references : [id] )

  createdAt DateTime @default(now())
}
