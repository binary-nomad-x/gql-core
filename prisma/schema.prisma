generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum Role {
  ADMIN
  MEMBER
}

model User {
  id String @id @default(uuid())
  email String @unique
  passwordHash String
  name String?
  role Role @default(MEMBER)
  createdAt DateTime @default(now())
}
