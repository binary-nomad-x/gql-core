# Dependency directories
node_modules/
jspm_packages/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment variables (SECURITY: Never commit these!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs
dist/
build/
out/
.next/
.nuxt/

# IDE/Editor specific files
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Operating System files
.DS_Store
Thumbs.db

# Optional: Docker files (if you don't want them in git)
.dockerignore

# Optional: Coverage reports (if using Jest/Mocha)
coverage/
.nyc_output/

# Optional: TypeScript cache
*.tsbuildinfo