{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "useDefineForClassFields": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "noEmit": false,
    "baseUrl": "./",
    "paths": {
      "@api/*": [
        "apps/api/src/*"
      ],
      "@frontend/*": [
        "apps/frontend/src/*"
      ],
      "@shared/*": [
        "libs/shared-types/*"
      ],
    },
  },
  "exclude": [
    "node_modules",
    "dist"
  ],
}