{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "@api/*": ["apps/api/src/*"],
      "@frontend/*": ["apps/frontend/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
